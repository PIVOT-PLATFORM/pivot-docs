@startuml PIVOT ACDD — Workflow agentique
!pragma layout smetana

skinparam backgroundColor #FAFAFA
skinparam defaultFontName "Arial"
skinparam defaultFontSize 10
skinparam ArrowThickness 1.5
skinparam ArrowColor #546E7A

skinparam activity {
  BackgroundColor #FFFFFF
  BorderColor #546E7A
  BorderThickness 1.5
  FontSize 10
  DiamondBackgroundColor #FFF9C4
  DiamondBorderColor #F9A825
  DiamondFontSize 9
}

skinparam partition {
  BackgroundColor #F5F5F5
  BorderColor #90A4AE
  FontSize 11
  FontStyle bold
}

skinparam note {
  BackgroundColor #FFFFF8
  BorderColor #90A4AE
  FontSize 9
}

title PIVOT — Workflow agentique ACDD\n(Acceptance Criteria Driven Development — Full Autonome)

|#E3F2FD| PO Agent |
start
:Lit **SPRINTS.md** — sprint courant\nLit fichiers US : Stage + Phase MVP;

:**Gate 1 — READINESS** (autonome)\nDoR check + score 0–100;

if (score ≥ 70 ?) then (oui)
  :Complète / valide les ACs\n→ **Stage: Ready**;
  note right
    PO Agent autonome —
    aucune intervention humaine
    pour valider les ACs
  end note
else (non)
  :Réécrit / clarifie les ACs\nRecalcule Gate 1;
  note right : Boucle interne jusqu'à ≥ 70
  detach
endif

|#E8F5E9| Architect + Security + QA |
:Revue AC\n• Faisabilité technique\n• Surface d'attaque (Red Team)\n• Couverture testable;

|#FCE4EC| Dev Agent |
:Crée branche\n**feat/us-{id}-{slug}**\n(checkout main → pull → new branch)\n→ **Stage: In progress**;

repeat
  :Code + tests\n(commit atomique);

  |#FFF9C4| Gates & Breaking Points |
  :**Gate 2 — COVERAGE**\nscore 0–100 par commit;

  if (score ?) then (≥ 85)
    note right : CONTINUE
  elseif (70–84) then (70–84)
    |#FCE4EC| Dev Agent |
    :Complète tests manquants;
    note right : AC sans test = non implémenté
  else (< 70)
    |#FCE4EC| Dev Agent |
    :Stop — label **needs-human-review**\nescalade QA Agent + mainteneur;
    detach
  endif

  |#FCE4EC| Dev Agent |

repeat while (US complète ?) is (non)
-> oui;

:Qualité : ESLint / Checkstyle /\nSpotBugs — 0 warning;
:Push branche + **ouvre PR**\n(Stage reste In progress);

|#EDE7F6| PR Review Agent |
:Gate 3 — analyse PR;
:CI pipeline (Plumber, Gitleaks,\nSemgrep, tests, build);

|#FFF9C4| Gates & Breaking Points |
:**Gate 3 — QUALITY**\nHard blocks check;

if (Hard block ?) then (oui)
  note right
    Hard blocks :
    • Secret Gitleaks
    • label security
    • breaking-change
    • contrat module modifié
  end note
  :Label **needs-human-review**\n+ escalade Breaking Point 2;
  detach
else (non)

  |#EDE7F6| PR Review Agent |
  :**Gate 4 — MERGE CONFIDENCE**\nscore 0–100\n(breakdown en commentaire PR);

  |#FFF9C4| Gates & Breaking Points |
  if (score Gate 4 ?) then (≥ 85)
    |#EDE7F6| PR Review Agent |
    :Pose **Stage → Review**\n+ signal mainteneur;
    :Merge autonome;
  elseif (60–84) then (60–84)
    |#EDE7F6| PR Review Agent |
    :Pose **Stage → Review**;
    :Merge documenté\n(commentaire breakdown);
  else (< 60)
    :→ **Breaking Point 2**\nLabel needs-human-review\n+ score breakdown;
    detach
  endif

endif

|#EFEBE9| Mainteneur (Human) |
:Review PR + merge\n**Stage → Done**;
note right
  Seul point d'intervention humaine.
  Claude ne pose JAMAIS Done.
end note

stop

@enduml
